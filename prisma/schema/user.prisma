// user table
model User {
  id BigInt @id
  user_name String
  nick_name String?
  gender Int?
  address String?
  birth_date DateTime?
  pick_left Int @default(0)
  voice_id Int @default(3)
  voice_speed Float @default(1.0)
  grant Int @default(0)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  deleted_at DateTime?
}